{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artagatitului.local/schema/recipe.schema.json",
  "title": "Arta Gătitului Recipe",
  "type": "object",
  "required": ["slug", "title", "category", "ingredients", "steps", "status"],
  "properties": {
    "id": { "type": "string" },
    "slug": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "category": { "type": "string", "minLength": 1 },
    "ingredients": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "beforeStart": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": { "type": "object" },
    "equipment": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prepTimeMinutes": { "type": ["integer", "null"], "minimum": 0 },
    "cookTimeMinutes": { "type": ["integer", "null"], "minimum": 0 },
    "totalTimeMinutes": { "type": ["integer", "null"], "minimum": 0 },
    "servings": { "type": ["integer", "string", "null"] },
    "image": { "type": ["string", "null"] },
    "sourceUrl": { "type": ["string", "null"] },
    "createdAt": { "type": ["string", "null"] },
    "updatedAt": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["published", "draft", "archived"]
    }
  },
  "additionalProperties": true
}
